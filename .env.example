# AI Provider (choose one)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here   # free at console.groq.com

# Optional alternative providers
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here

# AI_PROVIDER=google
# GOOGLE_API_KEY=your_google_key_here

# AI_PROVIDER=ollama  (no key needed, must have Ollama running locally)

# SauceDemo
SAUCEDEMO_URL=https://www.saucedemo.com

# App auth (set a strong password before sharing)
PLATFORM_USERNAME=admin
PLATFORM_PASSWORD=your-password
# Settings
HEADLESS_BROWSER=false
CLAUDE_MODEL=claude-sonnet-4-6
